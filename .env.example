# Copy to .env and fill in.

# SQLite for local/dev (zero setup). For production use Postgres:
#   DATABASE_URL="postgresql://user:pass@host:5432/podium"
# and change provider in prisma/schema.prisma to "postgresql".
DATABASE_URL="file:./dev.db"

# Master admin password (used at /admin/login)
ADMIN_PASSWORD="change-me-please"

# Secret used to sign the admin session cookie. Use a long random string.
SESSION_SECRET="please-change-this-to-a-long-random-string"
