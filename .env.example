# Copy to .env and fill in.

# --- Database ---
# SQLite for local/dev (zero setup). For production use Postgres:
#   DATABASE_URL="postgresql://user:pass@host:5432/podium"
# and change provider in prisma/schema.prisma to "postgresql".
DATABASE_URL="file:./dev.db"

# --- App ---
# Secret used to sign session cookies. Use a long random string.
SESSION_SECRET="please-change-this-to-a-long-random-string"
# Public base URL (used for Stripe redirect + share links). Optional locally.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Email that becomes the platform admin on signup (sees all accounts). Optional.
PLATFORM_ADMIN_EMAIL=""

# --- Stripe (subscriptions) ---
# Leave blank to run without billing (Free plan only). Fill in to enable Pro.
STRIPE_SECRET_KEY=""
# The recurring Price ID for your Pro plan (starts with price_...)
STRIPE_PRICE_ID=""
# Webhook signing secret (starts with whsec_...) from your Stripe webhook endpoint
STRIPE_WEBHOOK_SECRET=""
