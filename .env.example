# Copy to .env and fill in.

# SQLite for local/dev (zero setup). For production use Postgres:
#   DATABASE_URL="postgresql://user:pass@host:5432/podium"
DATABASE_URL="file:./dev.db"

# Who is the host/operator? This email is granted host powers (see all boards,
# all users, /host panel) when they sign up. The FIRST signup is also host if
# this is unset.
HOST_EMAIL=""

# ---- Stripe (optional for local dev; required to actually charge) ----
# Get these from https://dashboard.stripe.com/apikeys and
# https://dashboard.stripe.com/webhooks (for the webhook secret).
# Create a recurring Product + Price for the Pro plan and paste its price id.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""
# Public site URL (used for checkout success/cancel redirects). For dev:
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Secret used to sign session cookies. Use a long random string.
SESSION_SECRET="please-change-this-to-a-long-random-string"
