// Podium — multi-tenant leaderboard hosting SaaS
// Dev uses SQLite (zero setup). For production switch provider to "postgresql".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String   @id @default(cuid())
  email                String   @unique
  passwordHash         String
  name                 String   @default("")

  // Billing / subscription
  plan                 String   @default("free")     // "free" | "pro"
  subscriptionStatus   String   @default("inactive") // active | trialing | past_due | canceled | inactive
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?

  isPlatformAdmin      Boolean  @default(false)

  boards               Board[]

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Board {
  id          String   @id @default(cuid())
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId     String

  slug        String   @unique
  title       String
  subtitle    String   @default("")
  description String   @default("")
  rules       String   @default("")

  promoCode   String   @default("")
  ctaText     String   @default("")
  ctaUrl      String   @default("")
  accentColor String   @default("#f5b301")
  logoUrl     String   @default("")

  prizePool   String   @default("")
  currency    String   @default("$")
  socials     String   @default("{}")

  maskNames   Boolean  @default(true)
  isPublic    Boolean  @default(true)

  editorToken String   @unique @default(cuid())
  apiKey      String   @unique @default(cuid())

  entries     Entry[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
}

model Entry {
  id         String   @id @default(cuid())
  board      Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId    String

  username   String
  score      Float    @default(0)
  prize      String   @default("")
  avatarUrl  String   @default("")
  position   Int?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([boardId])
}
